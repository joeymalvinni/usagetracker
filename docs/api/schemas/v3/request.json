{
  "$defs": {
    "NotificationConfig": {
      "properties": {
        "cooldown_minutes": {
          "default": 15,
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "enabled": {
          "default": true,
          "type": "boolean"
        },
        "predictive_alerts": {
          "default": false,
          "type": "boolean"
        },
        "quiet_hours": {
          "anyOf": [
            {
              "$ref": "#/$defs/NotificationQuietHours"
            },
            {
              "type": "null"
            }
          ]
        },
        "reset_alerts": {
          "default": true,
          "type": "boolean"
        },
        "rules": {
          "items": {
            "$ref": "#/$defs/NotificationRule"
          },
          "type": "array"
        },
        "thresholds_percent_remaining": {
          "default": [
            50,
            25,
            10,
            5,
            0
          ],
          "items": {
            "format": "uint8",
            "maximum": 255,
            "minimum": 0,
            "type": "integer"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "NotificationQuietHours": {
      "properties": {
        "end_hour_local": {
          "format": "uint8",
          "maximum": 255,
          "minimum": 0,
          "type": "integer"
