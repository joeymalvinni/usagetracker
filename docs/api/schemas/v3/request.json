        "start_hour_local": {
          "format": "uint8",
          "maximum": 255,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "start_hour_local",
        "end_hour_local"
      ],
      "type": "object"
    },
    "NotificationRule": {
      "properties": {
        "account_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "enabled": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "predictive_alerts": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "reset_alerts": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "snoozed_until": {
          "format": "date-time",
          "type": [
            "string",
            "null"
          ]
        },
        "thresholds_percent_remaining": {
          "items": {
            "format": "uint8",
            "maximum": 255,
            "minimum": 0,
            "type": "integer"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "window_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "ProviderToggle": {
      "properties": {
        "enabled": {
          "type": "boolean"
