{
  "$defs": {
    "Account": {
      "properties": {
        "collection_enabled": {
          "default": true,
          "type": "boolean"
        },
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "display_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "display_name_source": {
          "$ref": "#/$defs/AccountDisplayNameSource",
          "default": "generated"
        },
        "email": {
          "type": [
            "string",
            "null"
          ]
        },
        "external_account_id": {
          "type": "string"
        },
        "hidden": {
          "default": false,
          "type": "boolean"
        },
        "id": {
          "type": "string"
        },
        "profile_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "provider_id": {
          "type": "string"
        },
        "updated_at": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "id",
        "provider_id",
        "external_account_id",
        "created_at",
        "updated_at"
      ],
      "type": "object"
    },
    "AccountDisplayNameSource": {
      "enum": [
        "provider",
        "generated",
        "user"
      ],
      "type": "string"
    },
    "AccountUsageSummary": {
      "properties": {
        "account_id": {
          "type": "string"
        },
        "activity": {
          "anyOf": [
            {
              "$ref": "#/$defs/ActivitySummary"
            },
            {
              "type": "null"
            }
          ]
        },
        "cost": {
          "anyOf": [
            {
              "$ref": "#/$defs/CostSummary"
            },
            {
              "type": "null"
            }
          ]
        },
        "provider_id": {
          "type": "string"
        },
        "reset_credits": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResetCreditSummary"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "provider_id",
        "account_id"
      ],
      "type": "object"
    },
    "ActivitySummary": {
      "properties": {
        "days": {
          "items": {
            "$ref": "#/$defs/DailyUsagePoint"
          },
          "type": "array"
        },
        "lifetime_tokens": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "lookback_tokens": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "provenance": {
          "$ref": "#/$defs/DataProvenance"
        },
        "today_tokens": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "provenance",
        "days",
        "today_tokens",
        "lookback_tokens"
      ],
      "type": "object"
    },
    "AddProviderAccountResponse": {
      "properties": {
        "display_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "profile_id": {
          "type": "string"
        },
        "profile_path": {
          "type": "string"
        },
        "provider_id": {
          "type": "string"
        }
      },
      "required": [
        "provider_id",
        "profile_id",
        "profile_path"
      ],
      "type": "object"
    },
    "AggregateProvenance": {
      "properties": {
        "estimated": {
          "type": "boolean"
        },
        "explanation": {
          "type": "string"
        },
        "mixed_scope": {
          "type": "boolean"
        },
        "partial": {
          "type": "boolean"
        },
        "qualities": {
          "items": {
            "$ref": "#/$defs/UsageDataQuality"
          },
          "type": "array"
        },
        "scopes": {
          "items": {
            "$ref": "#/$defs/UsageDataScope"
          },
          "type": "array"
        }
      },
      "required": [
        "scopes",
        "qualities",
        "partial",
        "estimated",
        "mixed_scope",
        "explanation"
      ],
      "type": "object"
    },
    "ApiCapability": {
      "enum": [
        "combined_state",
        "typed_errors",
        "usage_provenance",
        "refresh_jobs",
        "refresh_coalescing"
      ],
      "type": "string"
    },
    "ApiErrorCode": {
      "enum": [
        "invalid_json",
        "invalid_request",
        "request_too_large",
        "unsupported_method",
        "incompatible_protocol",
        "invalid_argument",
        "unknown_provider",
        "unknown_account",
        "unknown_refresh_job",
        "unsupported_operation",
        "conflict",
        "storage_unavailable",
        "internal"
      ],
      "type": "string"
    },
    "ApiErrorResponse": {
      "properties": {
        "code": {
          "$ref": "#/$defs/ApiErrorCode"
        },
        "message": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        }
      },
      "required": [
        "code",
        "message",
        "retryable"
      ],
      "type": "object"
    },
    "ConfigResponse": {
      "properties": {
        "config_path": {
          "type": "string"
        },
        "db_path": {
          "type": "string"
        },
        "notifications": {
          "$ref": "#/$defs/NotificationConfig",
          "default": {
            "cooldown_minutes": 15,
            "enabled": true,
            "predictive_alerts": false,
            "reset_alerts": true,
            "thresholds_percent_remaining": [
              50,
              25,
              10,
              5,
              0
            ]
          }
        },
        "poll_interval_seconds": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "providers": {
          "additionalProperties": {
            "$ref": "#/$defs/ProviderToggle"
          },
          "type": "object"
        },
        "socket_path": {
          "type": "string"
        }
      },
      "required": [
        "poll_interval_seconds",
        "config_path",
        "socket_path",
        "db_path",
        "providers"
      ],
      "type": "object"
    },
    "CostSummary": {
      "properties": {
        "days": {
          "items": {
            "$ref": "#/$defs/DailyUsagePoint"
          },
          "type": "array"
        },
        "lookback_cost_usd": {
          "format": "double",
          "type": "number"
        },
        "pricing": {
          "$ref": "#/$defs/PricingCoverage"
        },
        "provenance": {
          "$ref": "#/$defs/DataProvenance"
        },
        "today_cost_usd": {
          "format": "double",
          "type": "number"
        }
      },
      "required": [
        "provenance",
        "days",
        "today_cost_usd",
        "lookback_cost_usd",
        "pricing"
      ],
      "type": "object"
    },
    "DailyUsagePoint": {
      "properties": {
        "cost_usd": {
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "date": {
          "format": "date",
          "type": "string"
        },
        "priced_tokens": {
          "default": 0,
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "tokens": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "unpriced_tokens": {
          "default": 0,
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "date",
        "tokens"
      ],
      "type": "object"
    },
    "DataProvenance": {
      "properties": {
        "completeness": {
          "$ref": "#/$defs/UsageDataCompleteness"
        },
        "confidence": {
          "$ref": "#/$defs/UsageDataConfidence"
        },
        "quality": {
          "$ref": "#/$defs/UsageDataQuality"
        },
        "scope": {
          "$ref": "#/$defs/UsageDataScope"
        },
        "source": {
          "$ref": "#/$defs/UsageDataSource"
        }
      },
      "required": [
        "source",
        "scope",
        "quality",
        "completeness",
        "confidence"
      ],
      "type": "object"
    },
    "ForecastConfidence": {
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "type": "string"
    },
    "ForecastStatus": {
      "enum": [
        "insufficient_data",
        "safe",
        "on_pace",
        "at_risk",
        "exhausted"
      ],
      "type": "string"
    },
    "NotificationConfig": {
      "properties": {
        "cooldown_minutes": {
          "default": 15,
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "enabled": {
          "default": true,
          "type": "boolean"
        },
        "predictive_alerts": {
          "default": false,
          "type": "boolean"
        },
        "quiet_hours": {
          "anyOf": [
            {
              "$ref": "#/$defs/NotificationQuietHours"
            },
            {
              "type": "null"
            }
          ]
        },
        "reset_alerts": {
          "default": true,
          "type": "boolean"
        },
        "rules": {
          "items": {
            "$ref": "#/$defs/NotificationRule"
          },
          "type": "array"
        },
        "thresholds_percent_remaining": {
          "default": [
            50,
            25,
            10,
            5,
            0
          ],
          "items": {
            "format": "uint8",
            "maximum": 255,
            "minimum": 0,
            "type": "integer"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "NotificationQuietHours": {
      "properties": {
        "end_hour_local": {
          "format": "uint8",
          "maximum": 255,
          "minimum": 0,
          "type": "integer"
        },
        "start_hour_local": {
          "format": "uint8",
          "maximum": 255,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "start_hour_local",
        "end_hour_local"
      ],
      "type": "object"
    },
    "NotificationRule": {
      "properties": {
        "account_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "enabled": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "predictive_alerts": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "reset_alerts": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "snoozed_until": {
          "format": "date-time",
          "type": [
            "string",
            "null"
          ]
        },
        "thresholds_percent_remaining": {
          "items": {
            "format": "uint8",
            "maximum": 255,
            "minimum": 0,
            "type": "integer"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "window_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "PendingNotification": {
      "properties": {
        "body": {
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "id": {
          "format": "int64",
          "type": "integer"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "body",
        "created_at"
      ],
      "type": "object"
    },
    "PricingCoverage": {
      "properties": {
        "catalog_effective_from": {
          "format": "date",
          "type": [
            "string",
            "null"
          ]
        },
        "catalog_source": {
          "type": [
            "string",
            "null"
          ]
        },
        "catalog_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "covered_percent": {
          "format": "double",
          "type": "number"
        },
        "priced_tokens": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "unpriced_models": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "unpriced_tokens": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "priced_tokens",
        "unpriced_tokens",
        "covered_percent"
      ],
      "type": "object"
    },
    "ProviderActionResponse": {
      "properties": {
        "message": {
          "type": "string"
        },
        "provider_id": {
          "type": "string"
        }
      },
      "required": [
        "provider_id",
        "message"
      ],
      "type": "object"
    },
    "ProviderCapabilities": {
      "properties": {
        "add_account": {
          "type": "boolean"
        },
        "launch_account": {
          "type": "boolean"
        },
        "multiple_accounts": {
          "type": "boolean"
        },
        "repair": {
          "type": "boolean"
        },
        "setup": {
          "type": "boolean"
        },
        "workspace_setup": {
          "description": "Deprecated alias retained for v3 clients.",
          "type": "boolean"
        }
      },
      "required": [
        "multiple_accounts",
        "add_account",
        "repair",
        "launch_account",
        "workspace_setup"
      ],
      "type": "object"
    },
    "ProviderDescriptor": {
      "properties": {
        "capabilities": {
          "$ref": "#/$defs/ProviderCapabilities"
        },
        "display_name": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "minimum_refresh_interval_seconds": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "id",
        "display_name",
        "minimum_refresh_interval_seconds",
        "capabilities"
      ],
      "type": "object"
    },
    "ProviderHealth": {
      "properties": {
        "account_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "collection_mode": {
          "type": [
            "string",
            "null"
          ]
        },
        "last_error_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "last_error_message": {
          "type": [
            "string",
            "null"
          ]
        },
        "last_failure_at": {
          "format": "date-time",
          "type": [
            "string",
            "null"
          ]
        },
        "last_success_at": {
          "format": "date-time",
          "type": [
            "string",
            "null"
          ]
        },
        "provider_id": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/ProviderHealthStatus"
        },
        "updated_at": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "provider_id",
        "status",
        "updated_at"
      ],
      "type": "object"
    },
    "ProviderHealthStatus": {
      "enum": [
        "ok",
        "credentials_missing",
        "auth_failed",
        "rate_limited",
        "provider_error",
        "parse_error",
        "backing_off",
        "disabled"
      ],
      "type": "string"
    },
    "ProviderProfileResponse": {
      "properties": {
        "display_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "enabled": {
          "type": "boolean"
        },
        "id": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "enabled"
      ],
      "type": "object"
    },
    "ProviderRefreshResult": {
      "properties": {
        "account_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "collected_at": {
          "format": "date-time",
          "type": [
            "string",
            "null"
          ]
        },
        "collection_mode": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        },
        "provider_id": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/ProviderRefreshStatus"
        }
      },
      "required": [
        "provider_id",
        "status"
      ],
      "type": "object"
    },
    "ProviderRefreshStatus": {
      "enum": [
        "ok",
        "credentials_missing",
        "credentials_invalid",
        "unauthorized",
        "rate_limited",
        "network",
        "parse",
        "provider_unavailable",
        "storage_error",
        "disabled"
      ],
      "type": "string"
    },
    "ProviderSetupField": {
      "properties": {
        "help_text": {
          "type": [
            "string",
            "null"
          ]
        },
        "key": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ProviderSetupFieldKind"
        },
        "label": {
          "type": "string"
        },
        "options": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "required": {
          "type": "boolean"
        },
        "value": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "key",
        "label",
        "kind"
      ],
      "type": "object"
    },
    "ProviderSetupFieldKind": {
      "enum": [
        "select",
        "text",
        "secret"
      ],
      "type": "string"
    },
    "ProviderSetupResponse": {
      "properties": {
        "discovery_error": {
          "type": [
            "string",
            "null"
          ]
        },
        "fields": {
          "items": {
            "$ref": "#/$defs/ProviderSetupField"
          },
          "type": "array"
        },
        "profiles": {
          "items": {
            "$ref": "#/$defs/ProviderProfileResponse"
          },
          "type": "array"
        },
        "provider_id": {
          "type": "string"
        },
        "selected_workspace_id": {
          "description": "Deprecated OpenCode-specific fields retained for v3 clients.",
          "type": [
            "string",
            "null"
          ]
        },
        "workspace_options": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "provider_id",
        "profiles",
        "workspace_options"
      ],
      "type": "object"
    },
    "ProviderToggle": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "required": [
        "enabled"
      ],
      "type": "object"
    },
    "RefreshJob": {
      "properties": {
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "failure_message": {
          "type": [
            "string",
            "null"
          ]
        },
        "finished_at": {
          "format": "date-time",
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "provider_results": {
          "items": {
            "$ref": "#/$defs/ProviderRefreshResult"
          },
          "type": "array"
        },
        "scope": {
          "$ref": "#/$defs/RefreshScope"
        },
        "started_at": {
          "format": "date-time",
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "$ref": "#/$defs/RefreshJobStatus"
        },
        "trigger": {
          "$ref": "#/$defs/RefreshTrigger"
        }
      },
      "required": [
        "id",
        "scope",
        "trigger",
        "status",
        "created_at"
      ],
      "type": "object"
    },
    "RefreshJobStatus": {
      "enum": [
        "queued",
        "running",
        "completed",
        "failed"
      ],
      "type": "string"
    },
    "RefreshScope": {
      "properties": {
        "providers": {
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "RefreshTrigger": {
      "enum": [
        "manual",
        "system"
      ],
      "type": "string"
    },
    "ResetCredit": {
      "properties": {
        "expires_at": {
          "format": "date-time",
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "status"
      ],
      "type": "object"
    },
    "ResetCreditSummary": {
      "properties": {
        "available_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "credits": {
          "items": {
            "$ref": "#/$defs/ResetCredit"
          },
          "type": "array"
        },
        "next_expires_at": {
          "format": "date-time",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "available_count",
        "credits"
      ],
      "type": "object"
    },
    "ServerInfo": {
      "properties": {
        "api_version": {
          "const": 3,
          "type": "integer"
        },
        "capabilities": {
          "items": {
            "$ref": "#/$defs/ApiCapability"
          },
          "type": "array"
        },
        "providers": {
          "items": {
            "$ref": "#/$defs/ProviderDescriptor"
          },
          "type": "array"
        }
      },
      "required": [
        "api_version",
        "capabilities",
        "providers"
      ],
      "type": "object"
    },
    "StateSnapshot": {
      "properties": {
        "accounts": {
          "items": {
            "$ref": "#/$defs/Account"
          },
          "type": "array"
        },
        "config": {
          "$ref": "#/$defs/ConfigResponse"
        },
        "dashboard": {
          "$ref": "#/$defs/UsageDashboardSummary"
        },
        "forecasts": {
          "items": {
            "$ref": "#/$defs/UsageForecast"
          },
          "type": "array"
        },
        "generated_at": {
          "format": "date-time",
          "type": "string"
        },
        "health": {
          "items": {
            "$ref": "#/$defs/ProviderHealth"
          },
          "type": "array"
        },
        "server": {
          "$ref": "#/$defs/ServerInfo"
        },
        "snapshots": {
          "items": {
            "$ref": "#/$defs/UsageSnapshot"
          },
